// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())
  telegramId     String?       @unique
  walletAddress  String?       @unique
  username       String
  usernameLowercase String    @unique
  coins          Int           @default(0)
  xp             Int           @default(0)
  highScore      Int           @default(0)
  role           String        @default("player")
  banned         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ship           Ship?
  sessions       GameSession[]
  rewardClaims   RewardClaim[]

  @@index([highScore])
  @@index([createdAt])
}

model Ship {
  id             String        @id @default(uuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id])
  engineLevel    Int           @default(1)
  shieldLevel    Int           @default(1)
  fuelLevel      Int           @default(1)
  cargoBayLevel  Int           @default(1)
  magnetLevel    Int           @default(1)
}

model GameSession {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  distance       Int           @default(0)
  cargoCollected Int           @default(0)
  coinsEarned    Int           @default(0)
  xpEarned       Int           @default(0)
  damageTaken    Int           @default(0)
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([createdAt])
}

model RewardClaim {
  id            String   @id @default(uuid())
  userId        String
  walletAddress String
  amount        Int
  nonce         Int
  signature     String
  status        String   @default("approved")
  claimed       Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

// Singleton row (id = "singleton") holding admin-tunable economy + difficulty config.
model GameConfig {
  id                   String   @id @default("singleton")
  shieldUpgradeBaseCost Int     @default(150)
  fuelUpgradeBaseCost  Int      @default(125)
  minClaimAmount       Int      @default(100)
  coinToTokenRate      Int      @default(1)
  difficultySpeedScale Float    @default(1)
  difficultySpawnScale Float    @default(1)
  maintenanceMode      Boolean  @default(false)
  updatedAt            DateTime @updatedAt
}
